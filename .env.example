# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_warehouse
DB_USER=postgres
DB_PASSWORD=postgres

# API Configuration
API_BASE_URL=https://fakestoreapi.com
API_TIMEOUT=30
API_RETRIES=3

# Logging
LOG_LEVEL=INFO

# ETL Configuration
BATCH_SIZE=1000
CHUNK_SIZE=5000

# Scheduling
DAILY_RUN_TIME=02:00
TIMEZONE=UTC

# Alerting
ALERT_EMAIL=admin@example.com
